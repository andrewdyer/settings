{
  "name": "andrewdyer/settings",
  "description": "A simple, framework-agnostic settings container for PHP applications",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Anddye\\Settings\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Anddye\\Settings\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
